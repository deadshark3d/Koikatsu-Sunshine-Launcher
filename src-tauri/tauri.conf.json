{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koikatsu Sunshine Launcher",
  "version": "0.1.0",
  "identifier": "com.deadshark.koikatsusunshine-launcher",

  "mainBinaryName": "KoikatsuSunshineLauncher",

  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Koikatsu Sunshine Launcher",
        "width": 1024,
        "height": 576,
        "resizable": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": ["fonts/*"],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "bannerPath": "./wix-assets/banner.bmp",
        "dialogImagePath": "./wix-assets/dialog.bmp"
      }
    }
  }
}